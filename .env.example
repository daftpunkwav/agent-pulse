# ===== Server Config =====
AP_SERVER_HOST=0.0.0.0
AP_SERVER_PORT=8080
AP_SERVER_MODE=release  # debug | release | test (默认 release)
AP_SERVER_READ_TIMEOUT=30s
AP_SERVER_WRITE_TIMEOUT=30s
AP_SERVER_SHUTDOWN_TIMEOUT=30s
# CORS 白名单(逗号分隔,留空 = 不发送 CORS 头)
AP_SERVER_ALLOWED_ORIGINS=

# ===== Auth (v0.1.x MVP) =====
# 生产环境必须 AP_AUTH_ENABLED=true + AGENTPULSE_AUTH_API_KEYS 至少 1 个 key (>=16 字符)
# 推荐通过环境变量注入 key,避免配置文件误提交泄露。
AP_AUTH_ENABLED=false
AP_AUTH_OTLP_REQUIRE_KEY=true
# 多个 key 用英文逗号分隔
AGENTPULSE_AUTH_API_KEYS=

# ===== ClickHouse (Trace Storage) =====
AP_CLICKHOUSE_HOST=localhost
AP_CLICKHOUSE_PORT=9000
AP_CLICKHOUSE_DATABASE=agentpulse
AP_CLICKHOUSE_USER=default
AP_CLICKHOUSE_PASSWORD=
AP_CLICKHOUSE_TLS_ENABLED=false
AP_CLICKHOUSE_MAX_OPEN_CONNS=20
AP_CLICKHOUSE_MAX_IDLE_CONNS=10

# ===== PostgreSQL (Metadata) =====
AP_POSTGRES_HOST=localhost
AP_POSTGRES_PORT=5432
AP_POSTGRES_DATABASE=agentpulse
AP_POSTGRES_USER=agentpulse
# release 模式下禁止使用 changeme / 空密码
AP_POSTGRES_PASSWORD=
AP_POSTGRES_SSL_MODE=disable
AP_POSTGRES_MAX_OPEN_CONNS=20
AP_POSTGRES_MAX_IDLE_CONNS=10
AP_POSTGRES_MAX_LIFETIME=1h

# ===== Chroma (Vector Store, optional) =====
AP_CHROMA_HOST=localhost
AP_CHROMA_PORT=8000
AP_CHROMA_API_KEY=
AP_CHROMA_TENANT=default_tenant
AP_CHROMA_DATABASE=default_database

# ===== LLM Judge (for Online Evaluation) =====
AP_JUDGE_MODEL=gpt-4o-mini
AP_JUDGE_API_KEY=
AP_JUDGE_BASE_URL=https://api.openai.com/v1
AP_JUDGE_TIMEOUT=60s
AP_JUDGE_MAX_RETRIES=3
AP_JUDGE_CONCURRENCY=5

# OTLP Receiver (HTTP only — gRPC 4317 为 Phase 2 计划,当前未实现)
AP_OTLP_HTTP_PORT=4318
# 单次 OTLP 请求 body 上限(字节),默认 10MB
AP_OTLP_MAX_BODY_SIZE=10485760

# ===== Logging =====
AP_LOG_LEVEL=info
AP_LOG_FORMAT=json

# ===== Evaluation =====
AP_EVALUATION_SAMPLE_RATE=1.0
AP_EVALUATION_ASYNC_WORKERS=3
AP_EVALUATION_ASYNC_QUEUE_SIZE=1000
AP_EVALUATION_CACHE_TTL=24h
